#!/bin/sh
# Global pre-commit hook: documentation enforcement
# Install: git config --global core.hooksPath ~/.git-hooks

# Ensure CLI tools are on PATH (git hooks run in a minimal shell)
export PATH="/c/nvm4w/nodejs:$HOME/.local/bin:/usr/local/bin:$PATH"

# Get list of staged code files (excluding tests and package-lock)
STAGED_CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js)$' | grep -v '\.test\.' | grep -v 'package-lock.json')

# If there are code changes, check if docs were updated
if [ -n "$STAGED_CODE_FILES" ]; then
    STAGED_DOC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(CLAUDE\.md|README\.md)')
    if [ -z "$STAGED_DOC_FILES" ]; then
        echo "❌ ERROR: Code files modified but no documentation updated." >&2
        echo "" >&2
        echo "Modified code files:" >&2
        echo "$STAGED_CODE_FILES" | sed 's/^/  - /' >&2
        echo "" >&2
        echo "Please update CLAUDE.md or README.md to document your changes." >&2
        exit 1
    fi
fi

echo "✅ Documentation check passed" >&2
exit 0
